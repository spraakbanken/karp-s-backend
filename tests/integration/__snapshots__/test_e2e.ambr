  SearchResult(hits=[HitResponse(entry={'baseform': 'avbörda sig', 'wordforms': [], 'jfr': [], 'id': 'avborda_sig..1', 'text': '<p>(euf) göra fri från. Enligt NEO ”Hist.: sedan 1655.” Från lågtyskas\xa0<em>afbürden</em> med samma betydelse. ”Att lätta sin blåsa eller avbörda sig avföring är något som under alla omständigheter bör ske i tyst ensamhet.” (Ekenstam 1993) "I en variant ville grannkvinnan först \'låta en naturkraft avbörda sig\' och i en annan variant där hon går för att kissa blir hon mångordig och skriver \'ni vet fäll va\' ja\' menär\'." (Folksagan i Sverige 1 s 226)</p>'}, resource_id='fulaord'), HitResponse(entry={'baseform': 'avdelning för avgående gods', 'wordforms': [], 'jfr': [], 'id': 'avdelning_for_avgaende_gods..1', 'text': '<p>(sl) dass, toalett. I andra ändan har vi <em>avdelningen för</em> <em>ingående gods;</em> munnen. </p>'}, resource_id='fulaord'), HitResponse(entry={'baseform': 'avdunsta', 'wordforms': [], 'jfr': [], 'id': 'avdunsta..1', 'text': '<p>(sl) svimma, dö. </p>'}, resource_id='fulaord'), HitResponse(entry={'baseform': 'avdånad', 'wordforms': [], 'jfr': [], 'id': 'avdanad..1', 'text': '<p>(dial) död. (OFS) Jämför\xa0<em>dåna;</em> svimma från fornsvenska\xa0<em>dana;</em> bildning till samma ordstam som <em>dö.</em></p>'}, resource_id='fulaord'), HitResponse(entry={'baseform': 'avdöd', 'wordforms': [], 'jfr': [], 'id': 'avdod..1', 'text': '<p>(åld) avliden. Från fornsvenska\xa0<em>afdödher</em> till <em>av</em> i betydelsen bort och <em>död.</em> Enligt SO ”hist.:sedan 1435”. ”Den enda utvägen för henne att försona sig med Gud och återvinna sin samvetsfrid sade de var att hon, hennes make och hennes son med den avdöde horkarlen skulle upphöra att bola med den romerska skökan och ofördröjligen vända tillbaka till dem.” (von Krusensstjerna 1933/2004)</p>'}, resource_id='fulaord'), HitResponse(entry={'baseform': 'avelsam', 'wordforms': [], 'jfr': [], 'id': 'avelsam..1', 'text': '<p>(åld) fruktsam. ”När var nånsin en persianinna så avelsam som en europeiska?” (Wallenberg 1781/1960) </p>'}, resource_id='fulaord'), HitResponse(entry={'baseform': 'avelskorv', 'wordforms': [], 'jfr': [], 'id': 'avelskorv..1', 'text': '<p>se <em>korv</em> (1). </p>'}, resource_id='fulaord'), HitResponse(entry={'baseform': 'avelslem', 'wordforms': [], 'jfr': [], 'id': 'avelslem..1', 'text': '<p>se <em>lem.</em> </p>'}, resource_id='fulaord'), HitResponse(entry={'baseform': 'aveltyg', 'wordforms': [], 'jfr': [], 'id': 'aveltyg..1', 'text': '<p>(åld) könsorgan, förökningsredskap, av <em>avel;</em> avkastning, förökning och uppfödning av djur från\xa0<em>avla;</em> ge upphov till liv genom befruktning och <em>-tyg;</em> don, verktyg, redskap eller sak. Ordet återfunnit i Köttets poesi (1994), där det bl a talas om <em>kungliga aveltyg</em>.</p>'}, resource_id='fulaord'), HitResponse(entry={'baseform': 'avfall', 'wordforms': [], 'jfr': [], 'id': 'avfall..1', 'text': '<p>(dial) gotländska för dödsfall. (OSD) </p>'}, resource_id='fulaord')], resource_hits={'ao': 48, 'fulaord': 530, 'kelly': 470}, resource_order=['ao', 'fulaord', 'kelly'], total=1048)
